{
  "name": "sellova/domain",
  "description": "Sellova domain + services package (test harness)",
  "type": "project",
  "require": {
    "php": "^8.2",
    "illuminate/database": "^11.0",
    "illuminate/events": "^11.0",
    "illuminate/support": "^11.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit"
  }
}

