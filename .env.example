# -----------------------------------------------------------------------------
# Copy to `.env` and adjust. Never commit real secrets.
# -----------------------------------------------------------------------------

APP_NAME=Sellova
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Used by Laravel URL generation and Sanctum SPA config. In production use https://your-domain
ASSET_URL=

# -----------------------------------------------------------------------------
# Reverse proxy / TLS termination (nginx, Cloudflare, ELB, etc.)
# -----------------------------------------------------------------------------
# When true, Laravel trusts X-Forwarded-* from TRUSTED_PROXIES so APP_URL/https and client IP are correct.
TRUST_PROXIES=false
# Comma-separated IPs, or * to trust all proxies (only if TRUST_PROXIES=true).
TRUSTED_PROXIES=*

# -----------------------------------------------------------------------------
# Admin session (Inertia)
# -----------------------------------------------------------------------------
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
# Set true behind HTTPS so the session cookie is never sent over plain HTTP.
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

# -----------------------------------------------------------------------------
# Database (API + admin + Artisan)
# -----------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=sellova
DB_USERNAME=root
DB_PASSWORD=

# -----------------------------------------------------------------------------
# PHPUnit / CI mirrors (optional; phpunit.xml can set these instead)
# -----------------------------------------------------------------------------
TEST_DB_CONNECTION=mysql
TEST_DB_HOST=127.0.0.1
TEST_DB_PORT=3306
TEST_DB_DATABASE=sellova_test
TEST_DB_USERNAME=root
TEST_DB_PASSWORD=

# -----------------------------------------------------------------------------
# Cache & queue
# -----------------------------------------------------------------------------
CACHE_STORE=file
QUEUE_CONNECTION=sync
# For Horizon and Redis-backed queues/cache:
# CACHE_STORE=redis
# QUEUE_CONNECTION=redis
# Horizon UI: requires an admin session (viewHorizon) by default. Optional dev-only shortcut:
# HORIZON_ALLOW_LOCAL_UNAUTHENTICATED=true
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Mail (production: smtp, ses, postmark, etc.)
# -----------------------------------------------------------------------------
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# Sanctum (first-party SPA / future token API)
# -----------------------------------------------------------------------------
# Mobile JSON API today uses legacy Bearer tokens (see docs/PRODUCTION.md). Sanctum is available for
# SPA cookie auth or Personal Access Tokens once you wire routes to the `sanctum` guard.
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,127.0.0.1

# -----------------------------------------------------------------------------
# CORS (legacy /api for Flutter web, etc.)
# -----------------------------------------------------------------------------
# CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com

# -----------------------------------------------------------------------------
# Auth model (staff session uses StaffUser on same `users` table)
# -----------------------------------------------------------------------------
AUTH_MODEL=App\Models\StaffUser
